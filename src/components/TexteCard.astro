---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  image?: string;
  imageAlt?: string;
  about: string[];
}

const { title, description, date, slug, image, imageAlt, about } = Astro.props;

const formattedDate = date.toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="card">
  <a href={`/textes/${slug}`} class="card-link">
    <div class="card-image">
      {image ? (
        <img src={image} alt={imageAlt || title} loading="lazy" width="960" height="540" />
      ) : (
        <div class="card-placeholder" />
      )}
    </div>
    <div class="card-body">
      <div class="card-meta">
        <time datetime={date.toISOString().slice(0, 10)}>{formattedDate}</time>
        <div class="card-tags">
          {about.map((name) => <span class="tag">{name}</span>)}
        </div>
      </div>
      <h3 class="card-title">{title}</h3>
      <p class="card-description">{description}</p>
    </div>
  </a>
</article>

<style>
  .card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .card:hover .card-image img {
    transform: scale(1.03);
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-surface) 0%, var(--color-border) 100%);
  }

  .card-body {
    padding: var(--space-sm) var(--space-md);
    padding-bottom: var(--space-md);
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-xs);
  }

  .card-meta time {
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .card-tags {
    display: flex;
    gap: 0.3rem;
  }

  .card-title {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-xs);
  }

  .card-description {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    font-family: var(--font-serif);
    margin: 0;
  }
</style>
